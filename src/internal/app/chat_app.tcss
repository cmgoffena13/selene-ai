CommandPrompt {
    background: $surface;
    height: 5;
    margin: 1 0 1 1;
    min-width: 50;
    padding: 1;
    width: 1fr;
    overflow-y: auto;
    overflow-x: hidden;
}

#prompt_row {
    height: auto;
    width: 100%;
}

#attach_icon {
    width: 4;
    height: 5;
    content-align: center middle;
    margin: 1 1 1 1;
    text-align: center;
    color: $primary;
    background: $surface;
}

#chat_root {
    height: 1fr;
}

#session_controls {
    height: auto;
    padding: 0 0;
    margin: 1 1 0 1;
}

#session_select {
    width: 1fr;
    margin-right: 0;
}

/* Match default button label color for the "Sessions" placeholder (Select defaults to 50% foreground). */
#session_select SelectCurrent Static#label {
    color: $button-foreground;
}

#session_select SelectCurrent.-has-value Static#label {
    color: $foreground;
}

#new_session {
    min-width: 8;
    margin-right: 1;
}

#delete_session {
    min-width: 8;
    margin-right: 0;
}

#transcript {
    height: 1fr;
    padding: 1;
    overflow-y: auto;
    overflow-x: hidden;
}

.row {
    width: 100%;
    padding: 0 2;
    height: auto;
}

.spacer {
    width: 1fr;
}

.bubble {
    margin: 0 0;
    padding: 0;
    width: 80%;
    height: auto;
    box-sizing: border-box;
    background: $background;
    border: round $accent;
}

.bubble_content {
    width: 100%;
    height: auto;
    box-sizing: border-box;
    padding: 1 2;
    background: $surface;
}

.bubble_label {
    text-style: bold;
    color: $text;
    margin-bottom: 1;
    color: $primary;
}

.bubble_body {
    color: $primary;
    link-color: $primary;
    link-style: underline;
}

/*
 * Inline `code` in Markdown: default Textual uses bright $text-warning on dark.
 * ``bubble_body`` is a class on the Markdown widget itself (not a wrapper), so the
 * selector must be ``Markdown.bubble_body MarkdownBlock``, not ``.bubble_body Markdown …``.
 */
Markdown.bubble_body MarkdownBlock {
    &:dark > .code_inline {
        background: $surface;
        color: $text-muted;
        text-style: none;
    }
    &:light > .code_inline {
        background: $surface;
        color: $text-muted;
        text-style: none;
    }
    /* Fallback when :dark / :light do not match (some terminal color_system modes). */
    & > .code_inline {
        background: $surface;
        color: $text-muted;
        text-style: none;
    }
}

.bubble.user {
    border: round $primary;
}

.bubble.assistant {
}

.bubble.thinking {
}

.bubble.thinking .bubble_body {
    color: $text-muted;
}

.bubble.verbose {
    border: round $border;
}

.bubble.verbose .bubble_body {
    color: $text-muted;
}

.bubble.error {
    border: round $error;
}

.bubble.error .bubble_content {
    background: $error;
}

.bubble.error .bubble_label,
.bubble.error .bubble_body {
    color: $text;
}
