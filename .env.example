# Copy to the repo as `.env` for development
# or to ~/.config/selene_ai/.env for CLI / machine-wide overrides.
SELENE_LOG_LEVEL=ERROR
# Ollama model used by the CLI (e.g. llama3.2, mistral, etc.)
SELENE_OLLAMA_MODEL=gemma4:e2b
# Ollama embedding model used by the CLI (e.g. nomic-embed-text, nomic-embed-text-v2)
SELENE_OLLAMA_EMBEDDING_MODEL=nomic-embed-text
# Tavily API key for web search (get one at https://tavily.com)
SELENE_TAVILY_API_KEY=