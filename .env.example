# Copy to the repo as `.env` for development
# or to ~/.config/selene_ai/.env for CLI / machine-wide overrides.
SELENE_LOG_LEVEL=ERROR
# Ollama model used by the CLI (e.g. llama3.2, mistral)
SELENE_OLLAMA_MODEL=llama3.2
# Tavily API key for web search (get one at https://tavily.com)
SELENE_TAVILY_API_KEY=